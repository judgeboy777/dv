# Load iris dataset
data("iris")
print(iris)
# Simple scatter plot: Sepal Length vs Sepal Width
plot(iris$Sepal.Length, iris$Sepal.Width,
 main = "Scatter Plot: Sepal Length vs Sepal Width",
 xlab = "Sepal Length (cm)",
 ylab = "Sepal Width (cm)",
 col = iris$Species,
 pch = 19)
# Add legend
legend("topright", legend = levels(iris$Species),
 col = 1:3, pch = 19)
# Multivariate scatter plot: Sepal Length vs Petal Length, colored by Species
plot(iris$Sepal.Length, iris$Petal.Length,
     main = "Multivariate Scatter: Sepal vs Petal Length",
 xlab = "Sepal Length (cm)",
 ylab = "Petal Length (cm)",
 col = iris$Species,
 pch = 19)
# Scatter plot matrix
pairs(iris[1:4],
 main = "Scatter Plot Matrix of Iris Data",
 col = iris$Species,
 pch = 19)
